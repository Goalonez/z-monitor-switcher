{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Z Monitor Switcher",
  "version": "0.1.0",
  "identifier": "com.goalonez.monitorswitcher",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Z Monitor Switcher",
        "width": 540,
        "height": 760,
        "minWidth": 480,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Goalonez/z-monitor-switcher/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyN0UyMTZCNUJGNkE3RApSV1I5YXIrMUZ1SW5DR3JMZTE1NEhrWkNXYW4xT2VOS05IdkRHYmtkZ01HZG10dHJ3ZU80ajV0Wgo="
    }
  }
}
